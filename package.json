{
  "name": "plumes",
  "version": "1.0.0",
  "description": "A Mudlet GUI for the Oxidus mudlib.",
  "scripts": {
    "build": "npm @gesslar/muddy",
    "watch": "npm @gesslar/muddy -w",
    "major": "npm @gesslar/muddy version major",
    "minor": "npm @gesslar/muddy version minor",
    "patch": "npm @gesslar/muddy version patch",
    "test": "docker run --rm -v \"$PWD\":/workspace gesslardev/mudlet-busted",
    "test:tree": "docker run --rm -e BUSTED_OUTPUT=treeOutput -v \"$PWD\":/workspace gesslardev/mudlet-busted",
    "docker:update": "docker pull gesslardev/mudlet-busted",
    "pr": "gt submit -p --ai"
  },
  "license": "0BSD",
  "devDependencies": {
    "@gesslar/muddy": "file:../muddy"
  }
}
